df_tendencia = df.groupby(['Department', 'Year'])['Actual Amount'].sum().reset_index()

dados_comparacao = []

for dept in df['Department'].unique():
    dados_dept = df_tendencia[df_tendencia['Department'] == dept]
    
    X = dados_dept['Year'].values
    y = dados_dept['Actual Amount'].values
    
    coeficientes = np.polyfit(X, y, 1)
    inclinacao_m = coeficientes[0]
    intercepto_b = coeficientes[1]
    prev_2024 = max(0, (inclinacao_m * 2024) + intercepto_b)
    
    
    gasto_2023 = dados_dept[dados_dept['Year'] == 2023]['Actual Amount'].values[0]
    
    dados_comparacao.append({
        'Departamento': dept, 
        'Gasto_Real_2023': gasto_2023,
        'Previsao_2024': prev_2024
    })

df_previsao = pd.DataFrame(dados_comparacao)


